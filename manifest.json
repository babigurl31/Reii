{
  "manifest_version": 3,
  "name": "Lịch Trình Cá Nhân",
  "description": "Quản lý công việc & Giới hạn TikTok",
  "version": "1.2.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content.js"]
    }
  ]
}